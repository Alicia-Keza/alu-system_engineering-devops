#!/usr/bin/env bash
# Install and configure HAProxy
apt-get -y update
apt-get -y install haproxy

cat >> /etc/haproxy/haproxy.cfg <<EOF

frontend alx_front
    bind *:80
    default_backend alx_back

backend alx_back
    balance roundrobin
    server web-01 54.152.40.73:80 check
    server web-02 3.89.112.68:80 check
EOF

service haproxy restart

