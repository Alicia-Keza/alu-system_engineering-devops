#!/usr/bin/env bash
# Configures HAProxy to load balance between two web servers

apt-get -y update
apt-get -y install haproxy

# Build a fresh config
cat <<EOF > /etc/haproxy/haproxy.cfg
global
    daemon
    maxconn 256

defaults
    mode http
    timeout connect 5000ms
    timeout client 50000ms
    timeout server 50000ms

frontend http-in
    bind *:80
    default_backend webservers

backend webservers
    balance roundrobin
    server web-01 54.152.40.73:80 check
    server web-02 3.89.112.68:80 check
EOF

service nginx restart
