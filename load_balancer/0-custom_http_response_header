#!/usr/bin/env bash
# Configures Nginx with a custom HTTP response header

apt-get -y update
apt-get -y install nginx

# This detects if the server name has 'web-01' or 'web-02' and sets the header
SERVER_ID=$(hostname)
sed -i "s/server_name _;/server_name _;\n\tadd_header X-Served-By \"$SERVER_ID\";/" /etc/nginx/sites-available/default

service nginx restart
